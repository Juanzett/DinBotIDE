<Window x:Class="DinBotIDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DinBot IDE v1.0" Height="720" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BrushOscuro}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource BrushBorde}"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ══ TOOLBAR SUPERIOR ══ -->
        <ToolBar DockPanel.Dock="Top" Background="{StaticResource BrushPanel}"
                 Height="48" Padding="8,4">

            <Button Style="{StaticResource BotonDinBot}" Click="NuevoPrograma_Click"
                    ToolTip="Nuevo programa" Margin="2">
                📄 Nuevo
            </Button>
            <Button Style="{StaticResource BotonDinBot}" Click="AbrirPrograma_Click"
                    ToolTip="Abrir programa guardado" Margin="2">
                📂 Abrir
            </Button>
            <Button Style="{StaticResource BotonDinBot}" Click="GuardarPrograma_Click"
                    ToolTip="Guardar programa" Margin="2">
                💾 Guardar
            </Button>

            <Separator Margin="8,0"/>

            <!-- Selector de puerto COM -->
            <TextBlock Text="Puerto:" Foreground="{StaticResource BrushTexto}"
                       VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox x:Name="ComboPuertos" Width="100" Margin="4,0"
                      ToolTip="Puerto COM del DinBot"/>
            <Button Style="{StaticResource BotonDinBot}" Click="RefrescarPuertos_Click"
                    ToolTip="Buscar puertos COM disponibles" Margin="2">
                🔄
            </Button>

            <Separator Margin="8,0"/>

            <Button x:Name="BtnCompilar" Style="{StaticResource BotonDinBot}"
                    Click="Compilar_Click" ToolTip="Compilar código" Margin="2">
                🔨 Compilar
            </Button>
            <Button x:Name="BtnSubir" Style="{StaticResource BotonDinBot}"
                    Click="SubirAlRobot_Click" ToolTip="Subir al DinBot" Margin="2"
                    IsEnabled="False">
                ⬆️ Subir al DinBot
            </Button>

            <Separator Margin="8,0"/>

            <ToggleButton x:Name="BtnMonitorSerial" Click="ToggleMonitorSerial_Click"
                          Foreground="White" Background="#2A2A3A"
                          Padding="12,6" BorderThickness="0"
                          ToolTip="Abrir/cerrar monitor serial" Margin="2">
                📡 Monitor Serial
            </ToggleButton>
        </ToolBar>

        <!-- ═╬ STATUS BAR INFERIOR ════════-->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource BrushPanel}" Height="28">
            <StatusBarItem>
                <TextBlock x:Name="LblEstado" Text="Listo"
                           Foreground="{StaticResource BrushTexto}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="LblBloques" Text="Bloques: 0"
                               Foreground="{StaticResource BrushTexto}" FontSize="12"
                               Margin="0,0,16,0"/>
                    <TextBlock x:Name="LblPuerto" Text="Sin conexión"
                               Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ══ PANEL PRINCIPAL (3 columnas) ══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ── COLUMNA 1: Paleta de bloques ── -->
            <Border Grid.Column="0" Background="{StaticResource BrushPanel}"
                    BorderBrush="{StaticResource BrushBorde}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="🧱 Bloques"
                               Foreground="{StaticResource BrushPrimario}"
                               FontSize="14" FontWeight="Bold"
                               Padding="12,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelPaleta" Margin="8"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- ── COLUMNA 2: Canvas de bloques + código generado ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="200"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="200" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Canvas de bloques -->
                <Border Grid.Row="0" Background="#1A1A2A"
                        BorderBrush="{StaticResource BrushBorde}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🎨 Editor de Bloques"
                                   Foreground="{StaticResource BrushPrimario}"
                                   FontSize="13" FontWeight="Bold"
                                   Padding="12,8"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="CanvasBloques" Background="Transparent"
                                    Width="1200" Height="800"
                                    AllowDrop="True"
                                    Drop="Canvas_Drop"
                                    DragOver="Canvas_DragOver"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"/>

                <!-- Código Arduino generado -->
                <Border Grid.Row="2" Background="{StaticResource BrushPanel}"
                        BorderBrush="{StaticResource BrushBorde}" BorderThickness="1">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="8,4">
                            <TextBlock Text="⚡ Código Arduino Generado"
                                       Foreground="{StaticResource BrushPrimario}"
                                       FontSize="13" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource BotonDinBot}"
                                    Click="GenerarCodigo_Click"
                                    Padding="8,4" FontSize="11">
                                🔄 Regenerar
                            </Button>
                        </DockPanel>
                        <TextBox x:Name="TxtCodigoGenerado"
                                 Background="#0D0D1A" Foreground="#A8FF78"
                                 FontFamily="Consolas" FontSize="12"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0" Padding="8"/>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>

            <!-- ── COLUMNA 3: Monitor serial / Log ── -->
            <Border Grid.Column="4" Background="{StaticResource BrushPanel}"
                    BorderBrush="{StaticResource BrushBorde}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="📡 Monitor Serial"
                               Foreground="{StaticResource BrushPrimario}"
                               FontSize="14" FontWeight="Bold"
                               Padding="12,10"/>

                    <!-- Entrada serial -->
                    <DockPanel DockPanel.Dock="Bottom" Margin="8">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource BotonDinBot}"
                                Click="EnviarSerial_Click"
                                Padding="10,6" Margin="4,0,0,0">
                            Enviar
                        </Button>
                        <TextBox x:Name="TxtEntradaSerial"
                                 Background="#1A1A2A" Foreground="{StaticResource BrushTexto}"
                                 BorderBrush="{StaticResource BrushBorde}"
                                 Padding="6,4" FontFamily="Consolas"/>
                    </DockPanel>

                    <!-- Botones limpiar/conectar -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Margin="8,4" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BotonDinBot}"
                                Click="LimpiarSerial_Click"
                                Padding="8,4" FontSize="11" Margin="2">
                            🗑️ Limpiar
                        </Button>
                        <Button x:Name="BtnConectarSerial"
                                Style="{StaticResource BotonDinBot}"
                                Click="ConectarSerial_Click"
                                Padding="8,4" FontSize="11" Margin="2">
                            🔌 Conectar
                        </Button>
                    </StackPanel>

                    <!-- Salida serial -->
                    <TextBox x:Name="TxtSalidaSerial"
                             Background="#0D0D1A" Foreground="#00FF88"
                             FontFamily="Consolas" FontSize="11"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0" Padding="8"
                             TextWrapping="Wrap"
                             Margin="4"/>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
