<Application x:Class="DinBotIDE.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Paleta de colores DinBot IDE -->
        <Color x:Key="PrimaryColor">#2D2D30</Color>
        <Color x:Key="SecondaryColor">#3E3E42</Color>
        <Color x:Key="AccentColor">#FF6B00</Color>
        <Color x:Key="TextColor">#F1F1F1</Color>
        <Color x:Key="BlockMoveColor">#4CAF50</Color>
        <Color x:Key="BlockSensorColor">#2196F3</Color>
        <Color x:Key="BlockControlColor">#FF9800</Color>
        <Color x:Key="BlockSerialColor">#9C27B0</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    </Application.Resources>
</Application>